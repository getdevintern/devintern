{
  "name": "@devintern/task-trackers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "echo \"task-trackers: source-only package\"",
    "format": "oxfmt \"src/**/*.ts\" \"*.test.ts\"",
    "format:check": "oxfmt --check \"src/**/*.ts\" \"*.test.ts\"",
    "lint": "oxlint .",
    "typecheck": "bun run tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@devintern/text-formatter": "workspace:*",
    "@devintern/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.0"
  }
}
