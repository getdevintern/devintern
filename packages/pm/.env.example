# @devintern/pm Environment Configuration
# Copy this file to .devintern-pm/.env and update with your actual values

# Backend Configuration
# Which task backend to use: jira | linear | trello | azure-devops | asana | github | markdown
TASK_TRACKER=jira

# Markdown backend directory (relative to project root, only used when TASK_TRACKER=markdown)
# MARKDOWN_TASKS_DIR=.devintern-pm/tasks

# JIRA Configuration (TASK_TRACKER=jira)
# Creates issues via the Jira Cloud REST API v3. All four variables below are required.
#
# Your Jira site URL (without trailing slash):
#   https://your-org.atlassian.net/jira/... → JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_BASE_URL=https://your-org.atlassian.net

# Atlassian account email that owns the API token below
JIRA_EMAIL=your-email@example.com

# API token (required):
#   Create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token

# Default project key — short prefix on issue keys (PROJ in PROJ-123).
# Find it in any issue URL or Project settings → Details → Key.
JIRA_DEFAULT_PROJECT_KEY=PROJ

# Linear Configuration (TASK_TRACKER=linear)
# Creates issues via the Linear GraphQL API. Issue type selection is skipped —
# Linear does not expose Jira-style issue types through this integration.
#
# Personal API key (required):
#   Create at: https://linear.app/settings/api
#   1. Open Settings → API → Personal API keys
#   2. Click "Create key", add a label (e.g. DevIntern), copy the value
#   Keys start with lin_api_ and cannot be viewed again after creation.
LINEAR_API_KEY=lin_api_xxxxxxxxxxxx

# Default Linear team key (optional — uses the first accessible team if omitted).
# The team key is the short prefix before the issue number (ENG in ENG-42).
# Find it under Linear → Settings → Teams → [your team] → Key,
# or from any issue identifier in that team.
# LINEAR_DEFAULT_TEAM_KEY=ENG

# Trello Configuration
# TRELLO_API_KEY is optional — @devintern/pm includes a bundled Power-Up key by default.
# Only set this if you want to use your own Power-Up (isolated rate limits, enterprise use).
# To create your own: https://trello.com/power-ups/admin → API Key tab → Generate API Key
# TRELLO_API_KEY=your-trello-api-key

# Your Trello API token (required)
# Generate by visiting the authorize URL shown when you run devpm with TASK_TRACKER=trello,
# or manually: https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&name=DevIntern&key=YOUR_API_KEY
# Click "Allow" and paste the token shown on the next page
TRELLO_API_TOKEN=your-trello-api-token

# Default Trello board ID (optional, will use first board if not set)
# Copy the short ID from your board URL: https://trello.com/b/abc123/My-Board → abc123
# TRELLO_DEFAULT_BOARD_ID=abc123

# Default Trello list name (optional, will use first list on the board if not set)
# TRELLO_DEFAULT_LIST_NAME="To Do"

# Azure DevOps Configuration (TASK_TRACKER=azure-devops)
# Creates work items via the Azure DevOps REST API (dev.azure.com cloud only).
# All three variables below are required.
#
# Organization slug from your URL — use only the org name, not the full URL:
#   https://dev.azure.com/your-org/... → AZURE_DEVOPS_ORG=your-org
AZURE_DEVOPS_ORG=your-organization

# Personal Access Token (required):
#   Create at: https://dev.azure.com/your-org/_usersSettings/tokens
#   Scopes: Work Items (Read & write), Project and Team (Read)
#   Organization access: select your org (or All accessible organizations)
AZURE_DEVOPS_PAT=your-pat-token

# Default project name (required) — must match the project name exactly as shown in Azure DevOps.
# Find it in the URL: https://dev.azure.com/your-org/YourProject/... → YourProject
# Interactive mode also lets you switch projects with Ctrl+P.
AZURE_DEVOPS_PROJECT=YourProject

# Asana Configuration (TASK_TRACKER=asana)
# Personal Access Token with at least "default" scopes (tasks + projects).
# Create one at: https://app.asana.com/0/developer-console
ASANA_API_TOKEN=your-asana-pat

# Default Asana project GID (optional — uses the first accessible project if omitted).
# Open the project in Asana and copy the numeric ID after /project/ (not the project name):
#   https://app.asana.com/1/1111111111111111/project/2222222222222222/list/...
#     → ASANA_DEFAULT_PROJECT_GID=2222222222222222
# ASANA_DEFAULT_PROJECT_GID=2222222222222222

# GitHub Issues Configuration (TASK_TRACKER=github)
# Creates issues in a repository via the GitHub REST API.
# Issues show up under the repo's Issues tab.
#
# Personal Access Token — both token types work; fine-grained is preferred (least privilege).
#
# Fine-grained (recommended):
#   Create at: https://github.com/settings/personal-access-tokens/new
#   - Repository access: grant the target repo (and any others you want in the Ctrl+P repo picker)
#   - Permissions → Issues: Read and write
#   - Permissions → Metadata: Read (required, selected automatically)
#   - Org-owned repos: an org admin may need to approve the token
#
# Classic:
#   Create at: https://github.com/settings/tokens/new
#   - Private repos: select the "repo" scope (full control of private repositories)
#   - Public repos only: "public_repo" scope is enough
#
# Issue types map to labels: Story→enhancement, Bug→bug, Task→task, Epic→epic.
# Create those labels in the repo first, or issue creation may fail when applying labels.
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Target repository as owner/repo (e.g. acme/my-app)
GITHUB_REPO=your-username/your-repo

# Agent Harness Configuration
# Which AI agent to use: claude-code | opencode | codex | cursor | grok | deepseek
# (also: antigravity | kimi | qwen | goose | kilo-code | cline | pi)
# Legacy: gemini still resolves to antigravity with a deprecation warning
# Defaults to 'claude-code' if not specified
AGENT_HARNESS=claude-code

# Optional: Path to the agent CLI executable.
# Leave unset — by default devintern uses the harness's standard command
# (e.g. 'claude' for claude-code, 'grok' for grok, 'agy' for antigravity,
# 'reasonix' for deepseek) and locates it on your PATH automatically.
# Only set this if the CLI is NOT on your PATH or uses a non-standard name,
# in which case provide the command name or a full path.
# AGENT_CLI_PATH=/custom/path/to/claude

