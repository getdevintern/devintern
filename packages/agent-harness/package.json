{
  "name": "@devintern/agent-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Agent harness abstraction for running AI coding agents (Claude Code, Opencode, etc.)",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "echo \"agent-harness: source-only package\"",
    "format": "oxfmt \"src/**/*.ts\"",
    "format:check": "oxfmt --check \"src/**/*.ts\"",
    "lint": "oxlint .",
    "typecheck": "bun run tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "ai",
    "agent",
    "claude",
    "opencode",
    "codex",
    "cursor",
    "cli",
    "harness"
  ]
}
